{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "EtlKit/EtlKit.csproj",
            "EtlKit.Common/EtlKit.Common.csproj",
            "EtlKit.Primitives/EtlKit.Primitives.csproj",
            "EtlKit.Json/EtlKit.Json.csproj",
            "EtlKit.Kafka/EtlKit.Kafka.csproj",
            "EtlKit.Rest/EtlKit.Rest.csproj",
            "EtlKit.RabbitMq/EtlKit.RabbitMq.csproj",
            "EtlKit.Serialization/EtlKit.Serialization.csproj",
            "EtlKit.AI/EtlKit.AI.csproj",
            "EtlKit.Logging.Database/EtlKit.Logging.Database.csproj",
            "EtlKit.Scripting/EtlKit.Scripting.csproj",
            "EtlKit.DynamicLinq/EtlKit.DynamicLinq.csproj",
            "EtlKit.PostgresStreaming/EtlKit.PostgresStreaming.csproj"
          ],
          "src": ".."
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "netstandard2.0"
      },
      "filter": "filterConfig.yml"
    },
    {
      "src": [
        {
          "files": [
            "EtlKit.ClickHouse/EtlKit.ClickHouse.csproj"
          ],
          "src": ".."
        }
      ],
      "dest": "api/clickhouse",
      "properties": {
        "TargetFramework": "netstandard2.1"
      },
      "filter": "filterConfig.yml"
    },
    {
      "src": [
        {
          "files": [
            "EtlKit.MongoDB/EtlKit.MongoDB.csproj"
          ],
          "src": ".."
        }
      ],
      "dest": "api/mongodb",
      "properties": {
        "TargetFramework": "net6.0"
      },
      "filter": "filterConfig.yml"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "toc.yml",
          "index.md"
        ]
      }
    ],
    "dest": "../_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appTitle": "EtlKit Documentation",
      "_appFooter": "EtlKit \u2014 It's all in the box",
      "_enableSearch": true
    }
  }
}
